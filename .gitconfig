[user]
	name = Darius
	email = Reza.Blersch@gmail.com
[credential]
	helper = store
[init]
	defaultBranch = main
[fetch]
	prune = true

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    true-color = always
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection

[merge]
    conflictStyle = zdiff3
